# Coordinator
COORDINATOR_URL=https://coordinator.denvermc.com
COORDINATOR_TIMEOUT_MS=500
COORDINATOR_REGISTRATION_KEY=
# Bot token is auto-generated on first registration and stored in data/.bot_token

# MeshCore Connection
MESHCORE_CONNECTION_TYPE=serial
MESHCORE_SERIAL_PORT=/dev/ttyUSB0
# MESHCORE_TCP_HOST=192.168.1.100
# MESHCORE_TCP_PORT=5555
# MESHCORE_BLE_DEVICE_NAME=MeshCore

# Bot Identity
MESHCORE_BOT_NAME=MyCommunityBot
MESHCORE_LATITUDE=39.7392
MESHCORE_LONGITUDE=-104.9903
MESH_REGION=DEN

# Discord Webhooks (optional)
# DISCORD_BOT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_EMERGENCY_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_EMERGENCY_BROADCAST_CHANNEL=

# Timezone
TZ=America/Denver

# Web Viewer
WEB_VIEWER_ENABLED=true
WEB_VIEWER_PORT=8081

# External APIs (optional)
# N2YO_API_KEY=
# AIRNOW_API_KEY=
